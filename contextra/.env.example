# =====================================================
# Agentic System Configuration
# =====================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run:
#   python main.py

# =====================================================
# LLM PROVIDER — which LLM to use
# =====================================================
# Options: "claude", "openai", "ollama"
LLM_PROVIDER=claude

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- OpenAI (GPT) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.1
OPENAI_BASE_URL=
REASONING_EFFORT=medium

# --- Ollama (Local LLMs) ---
# First install Ollama: https://ollama.ai
# Then pull a model: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# =====================================================
# LLM PARAMETERS
# =====================================================
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.0

# =====================================================
# DATA PATHS
# =====================================================
# DATA_DIR: root of the artifact (parent of contextra/).
# All data is under DATA_DIR/data/.
# Defaults to ".." when run from inside contextra/.
DATA_DIR=..

# Target language: "python" or "java"
# Controls which repos, alerts, callgraphs, and CodeQL DBs are used.
LANGUAGE=python

# Override specific paths (usually not needed — set automatically by LANGUAGE):
# REPOS_DIR=../data/repos/python
# ISSUES_CSV=../data/alerts/python_sample_250_proportional.csv
# CALLGRAPH_JSON=../data/callgraphs/python_sample_callgraph.json
# CODEQL_DBS_DIR=../data/codeql_dbs/python

# =====================================================
# SYSTEM SETTINGS
# =====================================================
# Max agentic loop iterations per issue (default: 15)
MAX_ITERATIONS=15

# Classification mode: "stateless" or "conversation"
#   stateless    = rebuild full prompt every iteration (reproducible, more tokens)
#   conversation = send prompt once, then only tool results (cheaper, uses LLM memory)
MODE=conversation

# Show detailed tool execution logs
DEBUG=false

# Include call graph in the initial prompt?
# =====================================================
# =====================================================
# TOOL LIMITS (usually fine as defaults)
# =====================================================
# MAX_LINES_PER_GET=100
# MAX_GET_FILE_BYTES=100000
# MAX_SEARCH_MATCHES=50
# CONTEXT_LINES=12
# SEARCH_MAX_FILE_BYTES=1000000
